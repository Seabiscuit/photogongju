<!DOCTYPE html>
<html lang="<%= locals.isZh ? 'zh-CN' : 'en' %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <%- include('partials/seo-meta', {
        title: t('login.seoTitle'),
        description: t('login.seoDesc'),
        keywords: t('login.seoKeywords'),
        noindex: true
    }) %>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .login-page-wrap {
            min-height: calc(100vh - 64px - 80px);
            display: flex; align-items: center; justify-content: center;
            background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
            padding: 40px 20px;
        }
        .login-card {
            background: #fff; border-radius: 16px; padding: 40px 36px;
            width: 100%; max-width: 420px; box-shadow: 0 8px 30px rgba(0,0,0,0.1);
        }
        .login-card h2 { text-align: center; font-size: 1.5rem; margin-bottom: 4px; color: #1e293b; }
        .login-card .sub { text-align: center; font-size: 0.88rem; color: #64748b; margin-bottom: 28px; }
        .login-tabs { display: flex; margin-bottom: 24px; border-bottom: 2px solid #e2e8f0; }
        .login-tab {
            flex: 1; padding: 10px 0; text-align: center; cursor: pointer;
            font-size: 0.95rem; font-weight: 500; color: #64748b;
            border-bottom: 2px solid transparent; margin-bottom: -2px;
            transition: all 0.2s;
        }
        .login-tab.active { color: var(--color-primary); border-bottom-color: var(--color-primary); }
        .login-tab:hover { color: var(--color-primary-dark); }
        .form-panel { display: none; }
        .form-panel.active { display: block; }

        .form-group { margin-bottom: 16px; }
        .form-group label { display: block; font-size: 0.85rem; font-weight: 600; margin-bottom: 6px; color: #334155; }
        .login-card input[type="email"],
        .login-card input[type="password"],
        .login-card input[type="text"] {
            width: 100%; padding: 12px 14px; border: 1px solid #e2e8f0; border-radius: 8px;
            font-size: 0.95rem; transition: border-color 0.2s; font-family: inherit;
        }
        .login-card input:focus { outline: none; border-color: var(--color-primary); box-shadow: 0 0 0 3px rgba(14,165,163,0.1); }
        .login-card input::placeholder { color: #94a3b8; }

        .login-error {
            background: #fef2f2; color: #dc2626; border: 1px solid #fecaca;
            padding: 10px 14px; border-radius: 8px; font-size: 0.85rem; margin-bottom: 16px;
        }
        .login-success {
            background: #f0fdf4; color: #16a34a; border: 1px solid #bbf7d0;
            padding: 10px 14px; border-radius: 8px; font-size: 0.85rem; margin-bottom: 16px;
        }
        .btn-login {
            width: 100%; padding: 14px; font-size: 1rem; margin-top: 6px; font-weight: 600;
            background: linear-gradient(135deg, var(--color-primary-light), var(--color-primary));
            color: #fff; border: none; border-radius: 8px; cursor: pointer;
            box-shadow: 0 2px 8px rgba(14,165,163,0.3);
            transition: all 0.25s;
        }
        .btn-login:hover { box-shadow: 0 4px 16px rgba(14,165,163,0.4); transform: translateY(-1px); }
        .btn-login:disabled { opacity: 0.6; cursor: not-allowed; }

        .login-footer { text-align: center; margin-top: 20px; font-size: 0.88rem; color: #64748b; }
        .login-footer a { color: var(--color-primary); font-weight: 600; cursor: pointer; text-decoration: none; }
        .login-footer a:hover { text-decoration: underline; }

        .demo-tip {
            margin-top: 20px; padding: 14px 16px; background: #fffbeb; border: 1px solid #fde68a;
            border-radius: 10px; font-size: 0.8rem; color: #92400e; line-height: 1.6;
        }
        .demo-tip strong { color: #d97706; }
        .demo-tip code { background: #fef3c7; padding: 2px 6px; border-radius: 4px; font-size: 0.8rem; font-weight: 700; color: #b45309; }
    </style>
</head>
<body>

    <nav class="navbar">
        <div class="container">
            <a href="/" class="navbar-brand">
                <span class="brand-icon">📸</span>
                <span class="brand-text">PhotoGongju</span>
            </a>
            <div class="navbar-links">
                <a href="/" class="nav-link"><%= t('nav.home') %></a>
                <a href="/upload" class="nav-link"><%= t('nav.upload') %></a>
                <a href="/membership" class="nav-link"><%= t('nav.pricing') %></a>
            </div>
        </div>
    </nav>

    <div class="login-page-wrap">
        <div class="login-card">
            <h2 id="cardTitle"><%= t('login.title') %></h2>
            <p class="sub" id="cardSub"><%= t('login.subtitle') %></p>

            <% if (locals.success) { %>
                <div class="login-success"><%= success %></div>
            <% } %>
            <% if (locals.error) { %>
                <div class="login-error"><%= error %></div>
            <% } %>

            <!-- Tab 切换 -->
            <div class="login-tabs">
                <div class="login-tab active" data-tab="login" onclick="switchTab('login')">🔑 <%= t('login.passwordTab') %></div>
                <div class="login-tab" data-tab="register" onclick="switchTab('register')">📝 <%= t('login.register') %></div>
            </div>

            <!-- ★ 登录面板 -->
            <div class="form-panel active" id="loginPanel">
                <form method="POST" action="/login">
                    <input type="hidden" name="redirect" value="<%= locals.redirect || '/' %>">
                    <div class="form-group">
                        <label><%= t('login.email') %></label>
                        <input type="email" name="email" placeholder="<%= t('login.emailPlaceholder') %>"
                               autocomplete="email" required autofocus>
                    </div>
                    <div class="form-group">
                        <label><%= t('login.password') %></label>
                        <input type="password" name="password" placeholder="<%= t('login.passwordPlaceholder') %>"
                               autocomplete="current-password" required>
                    </div>
                    <button type="submit" class="btn-login"><%= t('login.submit') %></button>
                </form>
                <div class="login-footer">
                    <%= t('login.noAccount') %> <a onclick="switchTab('register')"><%= t('login.register') %></a>
                </div>
            </div>

            <!-- ★ 注册面板 -->
            <div class="form-panel" id="registerPanel">
                <form method="POST" action="/register" onsubmit="return validateRegister()">
                    <div class="form-group">
                        <label><%= t('login.email') %></label>
                        <input type="email" name="email" id="regEmail"
                               placeholder="<%= t('login.emailPlaceholder') %>"
                               autocomplete="email" required>
                    </div>
                    <div class="form-group">
                        <label><%= t('login.password') %></label>
                        <input type="password" name="password" id="regPassword"
                               placeholder="<%= t('login.passwordPlaceholder') %>" minlength="6"
                               autocomplete="new-password" required>
                    </div>
                    <div class="form-group">
                        <label><%= t('login.confirmPassword') %></label>
                        <input type="password" name="password2" id="regPassword2"
                               placeholder="<%= t('login.confirmPasswordPlaceholder') %>" minlength="6"
                               autocomplete="new-password" required>
                    </div>
                    <button type="submit" class="btn-login"><%= t('login.register') %></button>
                </form>
                <div class="login-footer">
                    <%= t('login.hasAccount') %> <a onclick="switchTab('login')"><%= t('login.backLogin') %></a>
                </div>
            </div>

            <!-- 演示账号提示 -->
            <div class="demo-tip">
                <strong>🧪 <%= t('login.demo') %></strong><br>
                <%= t('login.demoAccounts') %>:<br>
                <code>admin@photogongju.com</code> / <code>admin123</code><br>
                <code>test@photogongju.com</code> / <code>test123</code>
            </div>
        </div>
    </div>

    <footer class="footer">
        <div class="container"><p>© 2024 PhotoGongju</p></div>
    </footer>

    <script>
        function switchTab(tab) {
            document.querySelectorAll('.login-tab').forEach(t => t.classList.remove('active'));
            document.querySelector(`[data-tab="${tab}"]`).classList.add('active');
            document.getElementById('loginPanel').classList.toggle('active', tab === 'login');
            document.getElementById('registerPanel').classList.toggle('active', tab === 'register');

            var lang = '<%= locals.lang %>';
            if (lang === 'zh') {
                document.getElementById('cardTitle').textContent = tab === 'login' ? '欢迎回来' : '创建账号';
                document.getElementById('cardSub').textContent = tab === 'login' ? '登录 PhotoGongju 账号' : '注册 PhotoGongju 账号';
            } else {
                document.getElementById('cardTitle').textContent = tab === 'login' ? 'Welcome Back' : 'Create Account';
                document.getElementById('cardSub').textContent = tab === 'login' ? 'Sign in to PhotoGongju' : 'Register a PhotoGongju account';
            }

            if (tab === 'register') {
                setTimeout(() => document.getElementById('regEmail').focus(), 100);
            }
        }

        function validateRegister() {
            var pw = document.getElementById('regPassword').value;
            var pw2 = document.getElementById('regPassword2').value;
            if (pw.length < 6) {
                alert('<%= t("login.passwordShort") %>');
                return false;
            }
            if (pw !== pw2) {
                alert('<%= t("login.passwordMismatch") %>');
                return false;
            }
            return true;
        }
    </script>
</body>
</html>
