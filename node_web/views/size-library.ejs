<!DOCTYPE html>
<html lang="<%= locals.isZh ? 'zh-CN' : 'en' %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <%- include('partials/seo-meta', {
        title: t('nav.sizes') + ' - 50+ 常用图片尺寸预设 - PhotoGongju',
        description: 'PhotoGongju 尺寸规格库，50+ 常用图片尺寸预设。涵盖社交媒体(Instagram/微信/小红书)、电商(淘宝/京东/Amazon)、证件照(一寸/二寸/护照)、打印(A4/A3/照片)、壁纸等场景。',
        keywords: '图片尺寸,尺寸库,社交媒体尺寸,电商图片尺寸,证件照尺寸,打印尺寸,Instagram尺寸,淘宝主图尺寸',
        canonical: '/size-library'
    }) %>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .page-size-library .hero { padding: 48px 0 40px; background: linear-gradient(180deg, #f0fdfa 0%, #e6fffa 40%, #f8fafc 100%); }
        .page-size-library .hero h1 { font-size: 2rem; }
        .page-size-library .hero p { color: var(--color-text-secondary); font-size: 1rem; }

        .size-filter { display: flex; flex-wrap: wrap; justify-content: center; gap: 8px; margin-bottom: 28px; }
        .size-filter-btn {
            padding: 7px 18px; border-radius: 20px; border: 1px solid var(--color-border);
            background: #fff; color: var(--color-text-secondary); font-size: 0.85rem;
            font-weight: 500; cursor: pointer; transition: all 0.2s; font-family: inherit;
        }
        .size-filter-btn:hover, .size-filter-btn.active {
            background: var(--color-primary); color: #fff; border-color: var(--color-primary);
        }
        .size-table-wrap { overflow-x: auto; border-radius: var(--radius-md); box-shadow: var(--shadow-sm); border: 1px solid var(--color-border); margin-bottom: 60px; }
        .size-table { width: 100%; border-collapse: collapse; background: #fff; font-size: 0.93rem; }
        .size-table thead { background: linear-gradient(135deg, var(--color-primary-light), var(--color-primary)); }
        .size-table th { color: #fff; padding: 14px 16px; text-align: left; font-weight: 600; font-size: 0.85rem; white-space: nowrap; }
        .size-table td { padding: 12px 16px; border-bottom: 1px solid #f1f5f9; color: var(--color-text); }
        .size-table tbody tr:hover { background: #f0fdfa; }
        .size-table tbody tr:last-child td { border-bottom: none; }
        .size-name { font-weight: 600; }
        .size-ratio { font-family: monospace; font-size: 0.85rem; color: var(--color-text-secondary); }
        .size-cat-tag { display: inline-block; padding: 2px 10px; border-radius: 10px; font-size: 0.78rem; background: #e6fffa; color: var(--color-primary); font-weight: 500; }
    </style>
</head>
<body class="page-size-library">

    <nav class="navbar">
        <div class="container">
            <a href="/" class="navbar-brand">
                <span class="brand-icon">📸</span>
                <span class="brand-text">PhotoGongju</span>
            </a>
            <div class="navbar-links">
                <a href="/" class="nav-link"><%= t('nav.home') %></a>
                <a href="/upload" class="nav-link"><%= t('nav.upload') %></a>
                <a href="/size-library" class="nav-link active"><%= t('nav.sizes') %></a>
                <a href="/tutorial" class="nav-link"><%= t('nav.guide') %></a>
                <a href="/membership" class="nav-link"><%= t('nav.pricing') %></a>
            </div>
            <div class="navbar-actions">
                <% if (locals.isLoggedIn) { %>
                    <a href="/logout" class="btn btn-sm btn-outline"><%= locals.t('nav.logout') %></a>
                <% } else { %>
                    <a href="/login" class="btn btn-sm btn-outline"><%= locals.t('nav.login') %></a>
                    <a href="/upload" class="btn btn-sm btn-primary"><%= locals.t('nav.getStarted') %></a>
                <% } %>
            </div>
        </div>
    </nav>

    <!-- Hero -->
    <section class="hero">
        <div class="container">
            <h1><%= t('nav.sizes') %></h1>
            <p><%= locals.sizeLibrary.total %> 个预设尺寸 · 覆盖社交媒体、电商、打印等场景</p>
        </div>
    </section>

    <!-- Filter -->
    <section class="section" style="padding-top:20px">
        <div class="container">
            <div class="size-filter">
                <button class="size-filter-btn active" onclick="filterSizeCat('all')">全部</button>
                <% locals.sizeCategories.forEach(function(cat) { %>
                    <button class="size-filter-btn" onclick="filterSizeCat('<%= cat %>')"><%= cat %></button>
                <% }); %>
            </div>
            <div class="size-table-wrap">
                <table class="size-table">
                    <thead>
                        <tr>
                            <th>名称</th>
                            <th>宽度 (px)</th>
                            <th>高度 (px)</th>
                            <th>比例</th>
                            <th>分类</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% locals.sizeLibrary.presets.forEach(function(p) { %>
                            <tr data-category="<%= p.category %>">
                                <td class="size-name"><%= p.label %></td>
                                <td><%= p.width.toLocaleString() %></td>
                                <td><%= p.height.toLocaleString() %></td>
                                <td class="size-ratio"><%= p.width %>: <%= p.height %></td>
                                <td><span class="size-cat-tag"><%= p.category %></span></td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        </div>
    </section>

    <footer class="footer">
        <div class="container">
            <p style="text-align:center;color:var(--color-text-secondary);font-size:0.85rem;">© 2024 PhotoGongju</p>
        </div>
    </footer>

    <script>
        function filterSizeCat(cat) {
            document.querySelectorAll('.size-filter-btn').forEach(b => b.classList.remove('active'));
            event.target.classList.add('active');
            document.querySelectorAll('.size-table tbody tr').forEach(tr => {
                tr.style.display = (cat === 'all' || tr.dataset.category === cat) ? '' : 'none';
            });
        }
    </script>
</body>
</html>
