<!DOCTYPE html>
<html lang="<%= locals.isZh ? 'zh-CN' : 'en' %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <%- include('partials/seo-meta', {
        title: '开通VIP会员 - 解锁AI抠图高清证件照 | PhotoGongju',
        description: 'PhotoGongju会员套餐，开通VIP解锁AI智能抠图、高清证件照输出、批量处理、证件照换装等高级功能。单次/月卡/年卡多种套餐可选。',
        keywords: 'PhotoGongju会员,VIP会员,AI抠图会员,证件照高级功能,高清证件照',
        canonical: '/membership',
        noindex: true
    }) %>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        /* ── 会员页专属样式 ── */
        .membership-hero {
            background: linear-gradient(135deg, #1e1b4b 0%, #312e81 50%, #4338ca 100%);
            color: #fff;
            text-align: center;
            padding: 60px 20px 40px;
        }
        .membership-hero h1 { font-size: 2.2rem; margin-bottom: 8px; }
        .membership-hero .hero-sub { opacity: 0.8; font-size: 1.05rem; margin-bottom: 16px; }
        .current-badge {
            display: inline-block;
            padding: 6px 18px;
            border-radius: 20px;
            font-size: 0.9rem;
            font-weight: 600;
        }
        .badge-free { background: rgba(255,255,255,0.15); color: #cbd5e1; }
        .badge-vip { background: linear-gradient(135deg, #f59e0b, #ef4444); color: #fff; }
        .badge-admin { background: linear-gradient(135deg, #6366f1, #8b5cf6); color: #fff; }

        .plans-section { padding: 50px 20px; max-width: 1150px; margin: 0 auto; }
        .plans-grid { display: flex; gap: 24px; justify-content: center; flex-wrap: wrap; }
        .plan-card {
            flex: 1; min-width: 280px; max-width: 360px;
            background: #fff; border-radius: 16px; border: 2px solid #e2e8f0;
            padding: 32px 24px; text-align: center; position: relative;
            transition: all 0.25s; display: flex; flex-direction: column;
        }
        .plan-card:hover { transform: translateY(-4px); box-shadow: 0 12px 40px rgba(0,0,0,0.12); }
        .plan-card.popular { border-color: #f59e0b; box-shadow: 0 4px 24px rgba(245,158,11,0.15); }
        .popular-badge {
            position: absolute; top: -14px; left: 50%; transform: translateX(-50%);
            background: linear-gradient(135deg, #f59e0b, #ef4444); color: #fff;
            padding: 4px 20px; border-radius: 12px; font-size: 0.82rem; font-weight: 700;
        }
        .plan-name { font-size: 1.2rem; font-weight: 700; margin-bottom: 4px; }
        .plan-duration { font-size: 0.9rem; color: #64748b; margin-bottom: 16px; }
        .plan-price-wrap { margin-bottom: 20px; }
        .plan-price { font-size: 2.8rem; font-weight: 800; }
        .plan-price .unit { font-size: 1rem; font-weight: 500; color: #64748b; }
        .plan-original { font-size: 0.9rem; color: #94a3b8; text-decoration: line-through; margin-left: 4px; }
        .plan-features { text-align: left; list-style: none; margin: 0 0 24px; padding: 0; flex: 1; }
        .plan-features li {
            padding: 6px 0; font-size: 0.9rem; color: #334155;
            border-bottom: 1px solid #f1f5f9; display: flex; align-items: center; gap: 8px;
        }
        .plan-features li::before { content: "✓"; color: #10b981; font-weight: 700; font-size: 0.85rem; }
        .btn-buy {
            display: block; width: 100%; padding: 14px; border-radius: 10px;
            font-size: 1rem; font-weight: 700; border: none; cursor: pointer;
            color: #fff; transition: all 0.2s;
        }
        .btn-buy:hover { opacity: 0.9; transform: scale(1.02); }

        /* 限制提示区 */
        .restrictions-section { padding: 30px 20px 60px; max-width: 900px; margin: 0 auto; }
        .restrictions-section h3 { font-size: 1.2rem; margin-bottom: 16px; color: #475569; }
        .restriction-list { display: flex; flex-wrap: wrap; gap: 10px; }
        .restriction-tag {
            background: #fef2f2; color: #dc2626; border: 1px solid #fecaca;
            padding: 6px 14px; border-radius: 8px; font-size: 0.85rem;
            display: flex; align-items: center; gap: 6px;
        }
        .restriction-tag::before { content: "🔒"; font-size: 0.8rem; }

        /* 支付弹窗 */
        .pay-modal-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 1000; justify-content: center; align-items: center; }
        .pay-modal-overlay.show { display: flex; }
        .pay-modal {
            background: #fff; border-radius: 16px; padding: 32px; max-width: 420px; width: 90%; text-align: center;
        }
        .pay-modal h3 { margin-bottom: 16px; }
        .pay-modal .pay-price { font-size: 2rem; font-weight: 800; margin-bottom: 20px; color: #6366f1; }
        .pay-modal .pay-methods { display: flex; gap: 12px; justify-content: center; margin-bottom: 20px; }
        .pay-method {
            flex: 1; padding: 12px; border: 2px solid #e2e8f0; border-radius: 10px;
            cursor: pointer; font-size: 0.9rem; transition: all 0.2s;
        }
        .pay-method.active { border-color: #6366f1; background: #eef2ff; }
        .pay-qrcode { margin: 20px auto; width: 200px; height: 200px; background: #f1f5f9; border-radius: 12px; display: flex; align-items: center; justify-content: center; color: #94a3b8; font-size: 0.85rem; }
        .btn-pay-now { width: 100%; padding: 14px; font-size: 1rem; margin-top: 12px; }
        .pay-hint { font-size: 0.82rem; color: #94a3b8; margin-top: 12px; }
    </style>
</head>
<body class="<%= locals.bodyClass || '' %>">

    <!-- 导航栏 -->
    <nav class="navbar">
        <div class="container">
            <a href="/" class="navbar-brand">
                <span class="brand-icon">🖼️</span>
                <span class="brand-text">PhotoGongju</span>
            </a>
            <div class="navbar-links">
                <a href="/" class="nav-link">首页</a>
                <a href="/upload" class="nav-link">上传处理</a>
                <a href="/size-library" class="nav-link">尺寸库</a>
                <a href="/membership" class="nav-link active">会员</a>
            </div>
            <div class="navbar-status">
                <% if (locals.isLoggedIn) { %>
                    <span class="user-badge <%= locals.isVip ? 'is-vip' : '' %>">
                        <%= locals.isVip ? '👑' : '👤' %> <%= locals.user.name %>
                    </span>
                    <a href="/logout" class="nav-link">退出</a>
                <% } else { %>
                    <a href="/login" class="nav-link">登录</a>
                <% } %>
            </div>
        </div>
    </nav>

    <!-- Hero 区 -->
    <section class="membership-hero">
        <h1>开通会员，解锁全部功能</h1>
        <p class="hero-sub">更高效、更专业的图片处理体验</p>
        <% if (locals.currentTier && locals.currentTier !== 'free') { %>
            <span class="current-badge <%= locals.currentTier === 'admin' ? 'badge-admin' : 'badge-vip' %>">
                👑 当前: <%= locals.tierLabel %> · <%= locals.expireDesc %>
            </span>
        <% } else { %>
            <span class="current-badge badge-free">当前: 免费用户</span>
        <% } %>
    </section>

    <!-- 套餐对比 -->
    <section class="plans-section">
        <div class="plans-grid">
            <% Object.values(locals.plans || {}).forEach(function(plan) { %>
                <div class="plan-card <%= plan.popular ? 'popular' : '' %>">
                    <% if (plan.popular) { %>
                        <div class="popular-badge">🔥 热门推荐</div>
                    <% } %>
                    <div class="plan-name"><%= plan.name %></div>
                    <div class="plan-duration"><%= plan.durationLabel %></div>
                    <div class="plan-price-wrap">
                        <span class="plan-price"><span class="unit">¥</span><%= plan.price %></span>
                        <% if (plan.originalPrice > plan.price) { %>
                            <span class="plan-original">¥<%= plan.originalPrice %></span>
                        <% } %>
                    </div>
                    <ul class="plan-features">
                        <% plan.features.forEach(function(f) { %>
                            <li><%= f %></li>
                        <% }); %>
                    </ul>
                    <button class="btn-buy"
                            style="background: <%= plan.color %>"
                            onclick="openPayModal('<%= plan.id %>', '<%= plan.name %>', <%= plan.price %>)"
                            <%= locals.currentTier === plan.id ? 'disabled' : '' %>>
                        <% if (locals.currentTier === plan.id) { %>
                            ✅ 当前套餐
                        <% } else { %>
                            💰 立即开通
                        <% } %>
                    </button>
                </div>
            <% }); %>
        </div>
    </section>

    <!-- 免费用户限制提示 -->
    <% if (!locals.isVip && locals.restrictions && locals.restrictions.length > 0) { %>
    <section class="restrictions-section">
        <h3>🔒 以下功能需要开通会员</h3>
        <div class="restriction-list">
            <% locals.restrictions.forEach(function(r) { %>
                <span class="restriction-tag"><%= r.desc %></span>
            <% }); %>
        </div>
    </section>
    <% } %>

    <!-- 支付弹窗 -->
    <div class="pay-modal-overlay" id="payModal">
        <div class="pay-modal">
            <h3 id="payPlanName">单次付费</h3>
            <div class="pay-price" id="payPrice">¥9.9</div>

            <div class="pay-methods">
                <div class="pay-method active" data-method="alipay" onclick="selectPayMethod('alipay')">
                    💙 支付宝
                </div>
                <div class="pay-method" data-method="wxpay" onclick="selectPayMethod('wxpay')">
                    💚 微信
                </div>
            </div>

            <div class="pay-qrcode" id="payQrcode">
                <span id="qrcodeText">扫码支付</span>
            </div>
            <p style="font-size:0.85rem;color:#64748b;">支付后自动开通，无需手动操作</p>

            <button class="btn btn-primary btn-pay-now" id="btnPayNow" onclick="createOrder()">
                💳 生成支付订单
            </button>
            <a href="#" class="btn btn-outline" style="display:block;margin-top:8px;text-decoration:none;"
               id="btnMockPay" onclick="mockPay(event)" style="display:none">
                🧪 开发模式: 模拟支付
            </a>

            <p class="pay-hint">
                支持支付宝 / 微信扫码支付<br>
                支付成功后自动激活会员
            </p>

            <button class="btn btn-secondary" style="margin-top:12px;" onclick="closePayModal()">取消</button>
        </div>
    </div>

    <!-- 页脚 -->
    <footer class="footer">
        <div class="container"><p>© 2024 PhotoGongju</p></div>
    </footer>

    <script>
        // ══ 支付弹窗状态 ══
        let currentPayPlan = null;
        let currentPayMethod = 'alipay';
        let currentOrderId = null;
        let pollTimer = null;

        function openPayModal(planId, planName, price) {
            currentPayPlan = { planId, planName, price };
            document.getElementById('payPlanName').textContent = planName;
            document.getElementById('payPrice').textContent = '¥' + price;
            document.getElementById('payModal').classList.add('show');
            document.getElementById('btnMockPay').style.display = 'block';
            document.getElementById('btnPayNow').textContent = '💳 生成支付订单';
            document.getElementById('qrcodeText').textContent = '点击按钮生成支付';
        }

        function closePayModal() {
            document.getElementById('payModal').classList.remove('show');
            if (pollTimer) { clearInterval(pollTimer); pollTimer = null; }
        }

        function selectPayMethod(method) {
            currentPayMethod = method;
            document.querySelectorAll('.pay-method').forEach(el => el.classList.remove('active'));
            document.querySelector('[data-method="' + method + '"]').classList.add('active');
        }

        // ══ 创建订单 ══
        async function createOrder() {
            if (!currentPayPlan) return;

            const btn = document.getElementById('btnPayNow');
            btn.disabled = true;
            btn.textContent = '⏳ 创建中...';

            try {
                const res = await fetch('/api/payment/create-order', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ planId: currentPayPlan.planId }),
                });
                const data = await res.json();

                if (data.success) {
                    currentOrderId = data.orderId;
                    document.getElementById('qrcodeText').textContent =
                        '订单: ' + data.orderId + '\n金额: ¥' + currentPayPlan.price + '\n(模拟扫码支付)';
                    document.getElementById('btnPayNow').textContent = '✅ 订单已生成';
                    document.getElementById('btnMockPay').style.display = 'block';

                    // 开始轮询支付状态
                    startPolling(currentOrderId);
                } else {
                    alert('创建订单失败: ' + (data.error || '未知错误'));
                    btn.disabled = false;
                    btn.textContent = '💳 重试';
                }
            } catch (err) {
                alert('网络错误: ' + err.message);
                btn.disabled = false;
                btn.textContent = '💳 重试';
            }
        }

        // ══ 模拟支付（开发模式） ══
        async function mockPay(e) {
            e.preventDefault();
            if (!currentOrderId) {
                alert('请先生成支付订单');
                return;
            }

            const res = await fetch('/api/payment/callback?'
                + 'out_trade_no=' + currentOrderId
                + '&money=' + currentPayPlan.price
                + '&trade_status=TRADE_SUCCESS'
                + '&sign=dev_mock'
            );

            if (res.ok) {
                alert('支付成功！会员已激活 🎉');
                window.location.reload();
            } else {
                alert('支付处理失败，请重试');
            }
        }

        // ══ 轮询支付状态 ══
        function startPolling(orderId) {
            if (pollTimer) clearInterval(pollTimer);
            pollTimer = setInterval(async () => {
                try {
                    const res = await fetch('/api/payment/check/' + orderId);
                    const data = await res.json();
                    if (data.status === 'paid') {
                        clearInterval(pollTimer);
                        alert('支付成功！会员已激活 🎉');
                        window.location.reload();
                    }
                } catch (e) { /* 忽略轮询错误 */ }
            }, 3000);
        }

        // 点击遮罩关闭
        document.getElementById('payModal').addEventListener('click', function(e) {
            if (e.target === this) closePayModal();
        });
    </script>
</body>
</html>
