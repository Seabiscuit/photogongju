<!DOCTYPE html>
<html lang="<%= locals.isZh ? 'zh-CN' : 'en' %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <%- include('partials/seo-meta', {
        title: t('seo.homeTitle'),
        description: t('seo.homeDesc'),
        keywords: t('seo.homeKeywords'),
        canonical: '/'
    }) %>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="preload" href="/css/style.css" as="style">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="dns-prefetch" href="//hm.baidu.com">
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'><text y='28' font-size='28'>📸</text></svg>">
</head>
<body class="<%= locals.bodyClass || '' %>">

    <!-- ═══════════ Navigation ═══════════ -->
    <nav class="navbar">
        <div class="container">
            <a href="/" class="navbar-brand">
                <span class="brand-icon">📸</span>
                <span class="brand-text">PhotoGongju</span>
            </a>
            <div class="navbar-links">
                <a href="/" class="nav-link active"><%= t('nav.home') %></a>
                <a href="/upload" class="nav-link"><%= t('nav.upload') %></a>
                <a href="/size-library" class="nav-link"><%= t('nav.sizes') %></a>
                <a href="/tutorial" class="nav-link"><%= t('nav.guide') %></a>
                <a href="/membership" class="nav-link"><%= t('nav.pricing') %></a>
            </div>
            <div class="navbar-actions">
                <!-- Language Dropdown -->
                <div class="lang-dropdown">
                    <button class="lang-dropdown__toggle" aria-label="Switch language">
                        <svg class="lang-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                        <span class="lang-current"><%= locals.isZh ? '中文' : 'EN' %></span>
                        <svg class="lang-chevron" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
                    </button>
                    <div class="lang-dropdown__menu">
                        <button class="lang-dropdown__item <%= locals.isEn ? 'active' : '' %>" onclick="switchLang('en')">
                            <span class="lang-flag">🇺🇸</span> English
                        </button>
                        <button class="lang-dropdown__item <%= locals.isZh ? 'active' : '' %>" onclick="switchLang('zh')">
                            <span class="lang-flag">🇨🇳</span> 中文
                        </button>
                    </div>
                </div>
                <% if (locals.isLoggedIn) { %>
                    <span class="navbar-status">
                        <span class="status-dot online"></span>
                        <%= locals.user.name %>
                    </span>
                    <a href="/logout" class="btn btn-sm btn-outline"><%= locals.t('nav.logout') %></a>
                <% } else { %>
                    <a href="/login" class="btn btn-sm btn-outline"><%= locals.t('nav.login') %></a>
                    <a href="/upload" class="btn btn-sm btn-primary"><%= locals.t('nav.getStarted') %></a>
                <% } %>
            </div>
        </div>
    </nav>

    <!-- ═══════════ Hero ═══════════ -->
    <section class="hero">
        <div class="container">
            <div class="hero-badge">
                <span class="badge-dot"></span> <%= t('hero.badge') %>
            </div>
            <h1 class="hero-title"><%= t('hero.title1') %><br><%= t('hero.title2') %></h1>
            <p class="hero-subtitle"><%= t('hero.subtitle') %></p>
            <div class="hero-actions">
                <a href="/upload" class="btn btn-primary btn-lg btn-pill"><%= t('hero.cta1') %></a>
                <a href="/tutorial" class="btn btn-white btn-lg btn-pill"><%= t('hero.cta2') %></a>
            </div>
        </div>
    </section>

    <!-- ═══════════ How It Works ═══════════ -->
    <section class="section">
        <div class="container">
            <h2 class="section-title"><%= t('how.title') %></h2>
            <p class="section-subtitle"><%= t('how.subtitle') %></p>
            <div class="steps-grid">
                <div class="step-card">
                    <div class="step-number">1</div>
                    <h3><%= t('how.step1.title') %></h3>
                    <p><%= t('how.step1.desc') %></p>
                </div>
                <div class="step-card">
                    <div class="step-number">2</div>
                    <h3><%= t('how.step2.title') %></h3>
                    <p><%= t('how.step2.desc') %></p>
                </div>
                <div class="step-card">
                    <div class="step-number">3</div>
                    <h3><%= t('how.step3.title') %></h3>
                    <p><%= t('how.step3.desc') %></p>
                </div>
            </div>
        </div>
    </section>

    <!-- ═══════════ Features ═══════════ -->
    <section class="section section-gray">
        <div class="container">
            <h2 class="section-title"><%= t('features.title') %></h2>
            <p class="section-subtitle"><%= t('features.subtitle') %></p>
            <div class="features-grid">
                <a href="/upload" class="feature-card">
                    <span class="card-icon">🤖</span>
                    <h3><%= t('features.ai.title') %></h3>
                    <p><%= t('features.ai.desc') %></p>
                </a>
                <a href="/upload" class="feature-card">
                    <span class="card-icon">🎨</span>
                    <h3><%= t('features.bg.title') %></h3>
                    <p><%= t('features.bg.desc') %></p>
                </a>
                <a href="/upload" class="feature-card">
                    <span class="card-icon">📐</span>
                    <h3><%= t('features.resize.title') %></h3>
                    <p><%= t('features.resize.desc') %></p>
                </a>
                <a href="/upload" class="feature-card">
                    <span class="card-icon">✨</span>
                    <h3><%= t('features.enhance.title') %></h3>
                    <p><%= t('features.enhance.desc') %></p>
                </a>
                <a href="/upload" class="feature-card">
                    <span class="card-icon">🏷️</span>
                    <h3><%= t('features.watermark.title') %></h3>
                    <p><%= t('features.watermark.desc') %></p>
                </a>
                <a href="/size-library" class="feature-card">
                    <span class="card-icon">📋</span>
                    <h3><%= t('features.library.title') %></h3>
                    <p><%= t('features.library.desc') %></p>
                </a>
                <a href="/upload" class="feature-card">
                    <span class="card-icon">⚡</span>
                    <h3><%= t('features.batch.title') %></h3>
                    <p><%= t('features.batch.desc') %></p>
                </a>
                <a href="/membership" class="feature-card">
                    <span class="card-icon">👑</span>
                    <h3><%= t('features.premium.title') %></h3>
                    <p><%= t('features.premium.desc') %></p>
                </a>
            </div>
        </div>
    </section>

    <!-- ═══════════ Use Cases ═══════════ -->
    <section class="section">
        <div class="container">
            <h2 class="section-title"><%= t('usecases.title') %></h2>
            <p class="section-subtitle"><%= t('usecases.subtitle') %></p>
            <div class="usecases-grid">
                <div class="usecase-card">
                    <div class="usecase-icon">🪪</div>
                    <h4><%= t('usecases.id.title') %></h4>
                    <p><%= t('usecases.id.desc') %></p>
                </div>
                <div class="usecase-card">
                    <div class="usecase-icon">🛂</div>
                    <h4><%= t('usecases.passport.title') %></h4>
                    <p><%= t('usecases.passport.desc') %></p>
                </div>
                <div class="usecase-card">
                    <div class="usecase-icon">🎓</div>
                    <h4><%= t('usecases.graduation.title') %></h4>
                    <p><%= t('usecases.graduation.desc') %></p>
                </div>
                <div class="usecase-card">
                    <div class="usecase-icon">📱</div>
                    <h4><%= t('usecases.social.title') %></h4>
                    <p><%= t('usecases.social.desc') %></p>
                </div>
                <div class="usecase-card">
                    <div class="usecase-icon">🛒</div>
                    <h4><%= t('usecases.ecommerce.title') %></h4>
                    <p><%= t('usecases.ecommerce.desc') %></p>
                </div>
                <div class="usecase-card">
                    <div class="usecase-icon">🖨️</div>
                    <h4><%= t('usecases.print.title') %></h4>
                    <p><%= t('usecases.print.desc') %></p>
                </div>
            </div>
        </div>
    </section>

    <!-- ═══════════ Comparison ═══════════ -->
    <section class="section section-dark">
        <div class="container">
            <h2 class="section-title"><%= t('compare.title') %></h2>
            <p class="section-subtitle"><%= t('compare.subtitle') %></p>
            <div style="overflow-x:auto">
                <table class="compare-table">
                    <thead>
                        <tr>
                            <th><%= t('compare.feature') %></th>
                            <th><%= t('compare.us') %></th>
                            <th><%= t('compare.studio') %></th>
                            <th><%= t('compare.others') %></th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr><td><%= t('compare.price') %></td><td class="check"><%= t('compare.price.us') %></td><td><%= t('compare.price.studio') %></td><td><%= t('compare.price.others') %></td></tr>
                        <tr><td><%= t('compare.ai') %></td><td class="check"><%= t('compare.ai.us') %></td><td class="cross"><%= t('compare.ai.studio') %></td><td class="check"><%= t('compare.ai.others') %></td></tr>
                        <tr><td><%= t('compare.speed') %></td><td class="check"><%= t('compare.speed.us') %></td><td><%= t('compare.speed.studio') %></td><td><%= t('compare.speed.others') %></td></tr>
                        <tr><td><%= t('compare.presets') %></td><td class="check"><%= t('compare.presets.us') %></td><td class="check"><%= t('compare.presets.studio') %></td><td><%= t('compare.presets.others') %></td></tr>
                        <tr><td><%= t('compare.batch') %></td><td class="check"><%= t('compare.batch') %> ✓</td><td class="cross">✗</td><td class="cross">✗</td></tr>
                        <tr><td><%= t('compare.watermark') %></td><td class="check"><%= t('compare.watermark.us') %></td><td>N/A</td><td><%= t('compare.watermark.others') %></td></tr>
                        <tr><td><%= t('compare.privacy') %></td><td class="check"><%= t('compare.privacy.us') %></td><td><%= t('compare.privacy.studio') %></td><td><%= t('compare.privacy.others') %></td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </section>

    <!-- ═══════════ FAQ ═══════════ -->
    <section class="section">
        <div class="container">
            <h2 class="section-title"><%= t('faq.title') %></h2>
            <p class="section-subtitle"><%= t('faq.subtitle') %></p>
            <div class="faq-list">
                <div class="faq-item open">
                    <div class="faq-question" onclick="this.parentElement.classList.toggle('open')">
                        <%= t('faq.q1') %>
                    </div>
                    <div class="faq-answer"><%= t('faq.a1') %></div>
                </div>
                <div class="faq-item">
                    <div class="faq-question" onclick="this.parentElement.classList.toggle('open')">
                        <%= t('faq.q2') %>
                    </div>
                    <div class="faq-answer"><%= t('faq.a2') %></div>
                </div>
                <div class="faq-item">
                    <div class="faq-question" onclick="this.parentElement.classList.toggle('open')">
                        <%= t('faq.q3') %>
                    </div>
                    <div class="faq-answer"><%= t('faq.a3') %></div>
                </div>
                <div class="faq-item">
                    <div class="faq-question" onclick="this.parentElement.classList.toggle('open')">
                        <%= t('faq.q4') %>
                    </div>
                    <div class="faq-answer"><%= t('faq.a4') %></div>
                </div>
            </div>
        </div>
    </section>

    <!-- ═══════════ CTA ═══════════ -->
    <section class="section" style="text-align:center;background:linear-gradient(135deg,#f0fdfa,#e6fffa)">
        <div class="container">
            <h2 class="section-title"><%= t('cta.title') %></h2>
            <p class="section-subtitle"><%= t('cta.subtitle') %></p>
            <div class="hero-actions">
                <a href="/upload" class="btn btn-primary btn-lg btn-pill"><%= t('cta.btn1') %></a>
                <a href="/membership" class="btn btn-white btn-lg btn-pill"><%= t('cta.btn2') %></a>
            </div>
        </div>
    </section>

    <!-- ═══════════ Size Library ═══════════ -->
    <% if (locals.activeNav === 'size-library' && locals.sizeLibrary && locals.sizeLibrary.presets) { %>
    <section class="section">
        <div class="container">
            <h2 class="section-title"><%= t('nav.sizes') %></h2>
            <p class="section-subtitle"><%= locals.sizeLibrary.total %> 个预设尺寸 · <%= locals.sizeCategories.length %> 个分类 · 覆盖社交媒体、电商、打印等场景</p>
            <div class="size-filter">
                <button class="size-filter-btn active" onclick="filterSizeCat('all')">全部</button>
                <% locals.sizeCategories.forEach(function(cat) { %>
                    <button class="size-filter-btn" onclick="filterSizeCat('<%= cat %>')"><%= cat %></button>
                <% }); %>
            </div>
            <div class="size-table-wrap">
                <table class="size-table">
                    <thead><tr><th>名称</th><th>宽度 (px)</th><th>高度 (px)</th><th>比例</th><th>分类</th></tr></thead>
                    <tbody>
                        <% locals.sizeLibrary.presets.forEach(function(p) { %>
                            <tr data-category="<%= p.category %>">
                                <td class="size-name"><%= p.label %></td>
                                <td><%= p.width.toLocaleString() %></td>
                                <td><%= p.height.toLocaleString() %></td>
                                <td class="size-ratio"><%= p.width %>: <%= p.height %></td>
                                <td><span class="size-cat-tag"><%= p.category %></span></td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        </div>
    </section>
    <script>
        function filterSizeCat(cat) {
            document.querySelectorAll('.size-filter-btn').forEach(b => b.classList.remove('active'));
            event.target.classList.add('active');
            document.querySelectorAll('.size-table tbody tr').forEach(tr => {
                tr.style.display = (cat === 'all' || tr.dataset.category === cat) ? '' : 'none';
            });
        }
    </script>
    <% } %>

    <!-- ═══════════ Footer ═══════════ -->
        <div class="container">
            <div class="footer-grid">
                <div>
                    <div class="footer-brand">📸 PhotoGongju</div>
                    <p class="footer-desc"><%= t('footer.brand.desc') %></p>
                </div>
                <div>
                    <h4><%= t('footer.product') %></h4>
                    <a href="/upload"><%= t('footer.upload') %></a>
                    <a href="/size-library"><%= t('footer.sizes') %></a>
                    <a href="/membership"><%= t('footer.pricing') %></a>
                    <a href="/tutorial"><%= t('footer.guides') %></a>
                </div>
                <div>
                    <h4><%= t('footer.resources') %></h4>
                    <a href="/tutorial/how-to-take-id-photo"><%= t('footer.howto') %></a>
                    <a href="/tutorial/change-background"><%= t('footer.bgchange') %></a>
                    <a href="/tutorial/visa-photo-guide"><%= t('footer.visa') %></a>
                    <a href="/tutorial/photo-resize"><%= t('footer.resize') %></a>
                </div>
                <div>
                    <h4><%= t('footer.legal') %></h4>
                    <a href="#"><%= t('footer.privacy') %></a>
                    <a href="#"><%= t('footer.terms') %></a>
                    <a href="#"><%= t('footer.cookies') %></a>
                </div>
            </div>
            <div class="footer-bottom">
                <span><%= t('footer.copyright') %></span>
                <div class="footer-tech">
                    <span>FastAPI</span>
                    <span>Node.js</span>
                    <span>ONNX Runtime</span>
                    <span>AI Powered</span>
                </div>
            </div>
        </div>
    </footer>

    <script src="/js/main.js"></script>
</body>
</html>
